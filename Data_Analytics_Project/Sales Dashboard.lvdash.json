    {
      "name": "6beb0d8a",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "SELECT SUM(quantity) AS TotalQuantity\n",
        "FROM workspace.salesdb.fact_sales"
      ]
    },
    {
      "name": "93a6876d",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "-- sales over time \n",
        "select date_trunc('month', order_date) as orderdate, sum(fact_sales.sales_amount) as sales\n",
        "from workspace.salesdb.fact_sales\n",
        "group by orderdate\n"
      ]
    },
    {
      "name": "35b9ba0e",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "--sales by product category\n",
        "\n",
        "select dim_products.category, sum(sales_amount) as sales\n",
        "from workspace.salesdb.fact_sales\n",
        "join workspace.salesdb.dim_products on fact_sales.product_key = dim_products.product_key\n",
        "group by dim_products.category\n",
        "order by sales desc"
      ]
    }
  ],
