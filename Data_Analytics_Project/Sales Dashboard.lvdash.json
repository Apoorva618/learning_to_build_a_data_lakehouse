  "datasets": [
    {
      "name": "b540339b",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "\n",
        "SELECT SUM(sales_amount) AS TotalSales\n",
        "FROM workspace.salesdb.fact_sales"
      ]
    },
    {
      "name": "0c654081",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "SELECT SUM(fact_sales.sales_amount) - SUM(dim_products.cost * fact_sales.quantity) AS TotalProfit\n",
        "FROM workspace.salesdb.fact_sales\n",
        "JOIN workspace.salesdb.dim_products ON fact_sales.product_key = dim_products.product_key"
      ]
    },
