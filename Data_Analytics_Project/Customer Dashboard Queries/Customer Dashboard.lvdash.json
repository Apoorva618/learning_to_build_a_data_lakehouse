{
  "datasets": [
    {
      "name": "f678b4f3",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "select count(distinct customer_key) as TotalCustomers\n",
        "from workspace.salesdb.dim_customers"
      ]
    },
    {
      "name": "bb7c51e6",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "-- Average sales per customer \n",
        "WITH CustomerSales AS (\n",
        "    SELECT\n",
        "        dim_customers.customer_id,\n",
        "        SUM(fact_sales.price * fact_sales.quantity) AS TotalSales\n",
        "    FROM\n",
        "        fact_sales\n",
        "    JOIN\n",
        "        dim_customers ON fact_sales.customer_key = dim_customers.customer_key\n",
        "    GROUP BY\n",
        "        dim_customers.customer_id\n",
        ")\n",
        "SELECT\n",
        "    AVG(TotalSales) AS AverageSalesPerCustomer\n",
        "FROM\n",
        "    CustomerSales;\n"
      ]
    },
    {
      "name": "b8dc342b",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "select count(distinct order_number) as total_orders\n",
        "from workspace.salesdb.fact_sales"
      ]
    },
    {
      "name": "387aed49",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "WITH ranked_customers AS (\n",
        "  SELECT\n",
        "    c.`customer_key`,\n",
        "    c.`customer_id`,\n",
        "    c.`customer_number`,\n",
        "    c.`first_name`,\n",
        "    c.`last_name`,\n",
        "    SUM(s.`sales_amount`) AS total_sales,\n",
        "    RANK() OVER (ORDER BY SUM(s.`sales_amount`) DESC) AS sales_rank\n",
        "  FROM\n",
        "    `workspace`.`salesdb`.`fact_sales` s\n",
        "      JOIN `workspace`.`salesdb`.`dim_customers` c\n",
        "        ON s.`customer_key` = c.`customer_key`\n",
        "  WHERE\n",
        "    s.`sales_amount` IS NOT NULL\n",
        "    AND s.`customer_key` IS NOT NULL\n",
        "  GROUP BY\n",
        "    c.`customer_key`,\n",
        "    c.`customer_id`,\n",
        "    c.`customer_number`,\n",
        "    c.`first_name`,\n",
        "    c.`last_name`\n",
        ")\n",
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  ranked_customers\n",
        "WHERE\n",
        "  sales_rank <= 10\n",
        "ORDER BY\n",
        "  sales_rank;"
      ]
    }
  ],
